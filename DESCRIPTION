Type: Package
Package: derrick
Title: Export 'gtsummary' Tables with 'reporter'
Version: 0.1.1
Date: 2026-06-26
Authors@R: c(
    person("Xiecheng", "Gu", email = "guxc0405med@163.com", role = c("aut", "cre")),
    person("Joe", "Zhu", email = "sha.joe.zhu@gmail.com", role = c("aut")),
